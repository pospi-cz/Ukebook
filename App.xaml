<Application x:Class="Ukebook.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Výchozí světlé téma — přepíná ThemeService -->
                <ResourceDictionary Source="Themes/LightTheme.xaml"/>
                <!-- Styly tlačítek, listů atd. — používají DynamicResource -->
                <ResourceDictionary Source="Themes/MainTheme.xaml"/>
                <!-- Přepíše Aero2 šablony MenuItem (podmenu) — používá DynamicResource Menu*Brush -->
                <ResourceDictionary Source="Themes/MenuItemAeroOverrides.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
